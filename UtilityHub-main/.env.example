# Database Configuration (Render will provide this automatically)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/utilityhub

# Security
SECRET_KEY=your-secret-key-here

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=UtilityHub AI API

